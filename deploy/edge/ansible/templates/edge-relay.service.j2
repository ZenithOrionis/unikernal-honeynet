[Unit]
Description=Honeynet edge relay
After=network.target

[Service]
WorkingDirectory=/opt/honeynet/edge-relay
EnvironmentFile=/etc/honeynet-edge-relay.env
ExecStart=/opt/honeynet/edge-relay/.venv/bin/uvicorn app:app --host 0.0.0.0 --port 5001
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target

