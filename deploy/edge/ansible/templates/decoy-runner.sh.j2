#!/usr/bin/env bash
set -euo pipefail

command="${1:-}"
instance="${2:-}"
machine_name="honeynet-v2-${instance}"
app_dir="/opt/honeynet/releases/unikernel-decoy"
kraft_lock="${KRAFT_LOCK_FILE:-/run/honeynet-kraft.lock}"
startup_timeout_seconds="${STARTUP_TIMEOUT_SECONDS:-90}"
check_interval_seconds="${CHECK_INTERVAL_SECONDS:-10}"
failure_threshold="${FAILURE_THRESHOLD:-3}"
health_path="${HEALTHCHECK_PATH:-/}"
stopping=0

if [[ -z "${command}" || -z "${instance}" ]]; then
  echo "usage: $0 <start|stop> <instance>" >&2
  exit 2
fi

log() {
  printf '[decoy-runner][%s] %s\n' "${instance}" "$*"
}

with_kraft_lock() {
  local lock_dir

  lock_dir="$(dirname "${kraft_lock}")"
  mkdir -p "${lock_dir}"
  flock --close -w "${KRAFT_LOCK_TIMEOUT_SECONDS:-180}" "${kraft_lock}" "$@"
}

stop_instance() {
  with_kraft_lock bash -lc 'kraft --no-check-updates stop "$1" >/dev/null 2>&1 || true; kraft --no-check-updates remove "$1" >/dev/null 2>&1 || true' _ "${machine_name}"
}

start_instance() {
  log "launching ${machine_name} on host port ${HOST_PORT}"

  with_kraft_lock kraft --no-check-updates run -d \
      --plat qemu \
      --arch x86_64 \
      --name "${machine_name}" \
      --rm \
      -p "${HOST_PORT}:80" \
      "${app_dir}" \
      -- /app/decoy-server \
      --profile "${DECOY_PROFILE}" \
      --decoy-id "${DECOY_ID}" \
      --title "${DECOY_TITLE}" \
      --hostname "${DECOY_HOSTNAME}" \
      --label "${DECOY_LABEL}" \
      --collector-url "${COLLECTOR_URL}" \
      --collector-token "${COLLECTOR_TOKEN}" \
      --edge-node-id "${EDGE_NODE_ID}" \
      --decoy-version "${DECOY_VERSION}" \
      --public-endpoint "${PUBLIC_ENDPOINT}" \
      --site "${SITE}" \
      --environment "${ENVIRONMENT}" \
      --coverage-role "${COVERAGE_ROLE}" \
      --heartbeat-interval-seconds "${HEARTBEAT_INTERVAL_SECONDS}"
}

check_http_health() {
  local code

  code="$(curl -sS -o /dev/null -w '%{http_code}' --max-time 5 "http://127.0.0.1:${HOST_PORT}${health_path}" || true)"
  case "${code}" in
    2*|3*|401|403|404)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

wait_for_instance_ready() {
  local elapsed=0

  while (( elapsed < startup_timeout_seconds )); do
    if check_http_health; then
      log "decoy is reachable on http://127.0.0.1:${HOST_PORT}${health_path}"
      return 0
    fi

    sleep 2
    elapsed=$((elapsed + 2))
  done

  log "decoy did not become reachable within ${startup_timeout_seconds}s"
  return 1
}

shutdown() {
  stopping=1
  log "stopping ${machine_name}"
  stop_instance
}

if [[ "${command}" == "stop" ]]; then
  stop_instance
  exit 0
fi

if [[ "${command}" != "start" ]]; then
  echo "unknown command: ${command}" >&2
  exit 2
fi

stop_instance

trap shutdown INT TERM

start_instance
if ! wait_for_instance_ready; then
  stop_instance
  exit 1
fi

consecutive_failures=0

while (( stopping == 0 )); do
  sleep "${check_interval_seconds}" &
  wait $! || true

  if (( stopping != 0 )); then
    break
  fi

  if check_http_health; then
    consecutive_failures=0
    continue
  fi

  consecutive_failures=$((consecutive_failures + 1))
  log "health check failed (${consecutive_failures}/${failure_threshold}) on port ${HOST_PORT}"

  if (( consecutive_failures < failure_threshold )); then
    continue
  fi

  log "restarting ${machine_name} after repeated health check failures"
  stop_instance
  start_instance
  if wait_for_instance_ready; then
    consecutive_failures=0
  else
    log "restart failed to restore healthy state"
    stop_instance
    exit 1
  fi
done
